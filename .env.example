# Database (for direct run; docker-compose overrides this)
DATABASE_URL=mysql+pymysql://makerspace:makerspace@localhost:3306/makerspaceapi

# MariaDB (used by docker-compose)
DB_ROOT_PASSWORD=rootpassword
DB_NAME=makerspaceapi
DB_USER=makerspace
DB_PASSWORD=makerspace

# OIDC
OIDC_CLIENT_ID=makerspaceapi
OIDC_CLIENT_SECRET=your-client-secret-here
OIDC_DISCOVERY_URL=https://auth.example.com/.well-known/openid-configuration
OIDC_ADMIN_GROUP=makerspace-admins
OIDC_GROUP_CLAIM=groups
OIDC_REDIRECT_URI=http://localhost:8000/auth/callback

# App
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=false
BASE_URL=http://localhost:8000

# Optional: comma-separated slugs of checkout box devices
# (restricts user creation endpoint to these devices)
CHECKOUT_BOX_SLUGS=nfckasse
