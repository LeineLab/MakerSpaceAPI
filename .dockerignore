.git/
.github/

# Local config / secrets
.env
.env.*
!.env.example

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/

# Node (Tailwind CSS is pre-built and committed)
node_modules/

